# === Database ===
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# === External Services ===
RISK_SCORE_URL=https://your-risk-score-service.up.railway.app/risk-score
FRAUD_VALIDATE_URL=http://localhost:8003/fraud-validate
# LangGraph Orchestrator URL (used by admin/override to forward disruption events)
LANGGRAPH_ORCHESTRATOR_URL=http://localhost:8002/webhook/orchestrate

# === Server ===
PORT=3000
NODE_ENV=development

# === Auth ===
# REQUIRED in production — no default fallback allowed
JWT_SECRET=replace-me-with-a-secure-random-string
