{
  "name": "Workflow 2 – Curfew Trigger",
  "nodes": [

    {
      "id": "schedule",
      "name": "Every 10 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [200,300],
      "parameters": {
        "rule": {
          "interval":[{ "field":"minutes","minutesInterval":10 }]
        }
      }
    },

    {
      "id": "news",
      "name": "Get News",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450,200],
      "parameters": {
        "url":"https://newsapi.org/v2/everything",
        "sendQuery": true,
        "queryParameters": {
          "parameters":[
            { "name":"q","value":"curfew vadodara OR bandh vadodara OR curfew gujarat" },
            { "name":"language","value":"en" },
            { "name":"pageSize","value":"5" },
            { "name":"apiKey","value":"b03d0880144045ad90bc491595f1ddb4" }
          ]
        }
      }
    },

    {
      "id": "orders",
      "name": "Get Orders",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450,420],
      "parameters": {
        "url":"https://n8n-production-dca8.up.railway.app/webhook/orders"
      }
    },

    {
      "id": "merge",
      "name": "Merge News + Orders",
      "type": "n8n-nodes-base.merge",
      "position": [650,300],
      "parameters": {
        "mode":"append"
      }
    },

    {
      "id": "check",
      "name": "Trigger Check",
      "type": "n8n-nodes-base.if",
      "position": [850,300],
      "parameters": {
        "conditions": {
          "combinator":"or",
          "conditions":[

            {
              "leftValue":"={{ $items(\"Get News\")[0].json.totalResults }}",
              "rightValue":0,
              "operator":{
                "type":"number",
                "operation":"gt"
              }
            },

            {
              "leftValue":"={{ $items(\"Get Orders\")[0].json.orders }}",
              "rightValue":0,
              "operator":{
                "type":"number",
                "operation":"eq"
              }
            }

          ]
        }
      }
    },

    {
      "id": "dedup",
      "name": "Dedup Check",
      "type": "n8n-nodes-base.postgres",
      "position": [1050,300],
      "parameters": {
        "operation":"executeQuery",
        "query":
        "SELECT id FROM disruption_events WHERE zone_id='VAD-04' AND created_at > NOW() - INTERVAL '1 hour' LIMIT 1;"
      },
      "credentials": {
        "postgres": {
          "id": "postgresql://neondb_owner:npg_7mQUOejGdH4I@ep-snowy-grass-a1wk1jtu-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require",
          "name": "Postgres account"
        }
      }
    },

    {
      "id": "check2",
      "name": "No Recent Event",
      "type": "n8n-nodes-base.if",
      "position": [1250,300],
      "parameters": {
        "conditions": {
          "conditions":[
            {
              "leftValue":"={{ $json.id }}",
              "operator":{
                "type":"string",
                "operation":"isEmpty"
              }
            }
          ]
        }
      }
    },

    {
      "id": "webhook",
      "name": "Call Orchestrator",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1450,300],
      "parameters": {
        "method":"POST",
        "url":"https://uncapitulating-vinita-preorbital.ngrok-free.dev/webhook/orchestrate",
        "sendBody":true,
        "contentType":"json",
        "body":
        "={\"zone_id\":\"VAD-04\",\"trigger_id\":\"T4\",\"severity\":\"HIGH\",\"disruption_start\":\"{{$now}}\"}"
      }
    },

    {
      "id": "insert",
      "name": "Insert DB",
      "type": "n8n-nodes-base.postgres",
      "position": [1650,300],
      "parameters": {
        "operation":"executeQuery",
        "query":
        "INSERT INTO disruption_events(zone_id,trigger_id,severity,disruption_start,created_at) VALUES('VAD-04','T4','HIGH',NOW(),NOW());"
      },
      "credentials": {
        "postgres": {
          "id": "postgresql://neondb_owner:npg_7mQUOejGdH4I@ep-snowy-grass-a1wk1jtu-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require",
          "name": "Postgres account"
        }
      }
    }

  ],

  "connections": {

    "Every 10 Minutes": {
      "main":[[
        { "node":"Get News","type":"main","index":0 },
        { "node":"Get Orders","type":"main","index":0 }
      ]]
    },

    "Get News": {
      "main":[[
        { "node":"Merge News + Orders","type":"main","index":0 }
      ]]
    },

    "Get Orders": {
      "main":[[
        { "node":"Merge News + Orders","type":"main","index":1 }
      ]]
    },

    "Merge News + Orders": {
      "main":[[
        { "node":"Trigger Check","type":"main","index":0 }
      ]]
    },

    "Trigger Check": {
      "main":[[
        { "node":"Dedup Check","type":"main","index":0 }
      ],[]]
    },

    "Dedup Check": {
      "main":[[
        { "node":"No Recent Event","type":"main","index":0 }
      ]]
    },

    "No Recent Event": {
      "main":[[
        { "node":"Call Orchestrator","type":"main","index":0 }
      ],[]]
    },

    "Call Orchestrator": {
      "main":[[
        { "node":"Insert DB","type":"main","index":0 }
      ]]
    }

  }
}