{
  "name": "Mock Orders API",
  "nodes": [
    {
      "id": "webhook",
      "name": "Orders Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [300, 300],
      "parameters": {
        "path": "orders",
        "httpMethod": "GET",
        "responseMode": "responseNode"
      }
    },

    {
      "id": "set",
      "name": "Mock Orders Data",
      "type": "n8n-nodes-base.set",
      "position": [550, 300],
      "parameters": {
        "values": {
          "string": [
            {
              "name": "zone",
              "value": "VAD-04"
            },
            {
              "name": "status",
              "value": "OK"
            }
          ],
          "number": [
            {
              "name": "orders",
              "value": 0
            }
          ]
        }
      }
    },

    {
      "id": "respond",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [800, 300],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}"
      }
    }
  ],

  "connections": {
    "Orders Webhook": {
      "main": [
        [
          {
            "node": "Mock Orders Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },

    "Mock Orders Data": {
      "main": [
        [
          {
            "node": "Respond",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}